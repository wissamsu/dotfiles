{
  "yaml.schemas": {
    "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": "compose.yaml",
    "kubernetes": [
      "app2.yaml",
      "app.yaml",
    ],
    "http://json.schemastore.org/github-workflow": ".github/workflows/*",
    "http://json.schemastore.org/kustomization": "kustomization.yaml"
  },
  "yaml.completion": true,
  "yaml.hover": true,
  "yaml.format.enable": true,
  "rust-analyzer.inlayHints.chainingHints.enable": false,
  "rust-analyzer.lens.run.enable": false,
  "rust-analyzer.lens.debug.enable": false,
  "diagnostic.refreshOnInsertMode": false,
  "java.configuration.updateBuildConfiguration": "interactive",
  "inlayHint.refreshOnInsertMode": true,
  "codeLens.position": "eol",
  "codeLens.enable": true,
  "coc.preferences.useQuickfixForLocations": true,
  "coc.preferences.formatOnSave": true,
  "coc.preferences.willSaveHandlerTimeout": 500,
  "suggest.autoTrigger": "always",
  "suggest.timeout": 5000,
  "suggest.triggerAfterInsertEnter": true,
  "suggest.maxCompleteItemCount": 20,
  "suggest.virtualText": false,
  "coc.source.buffer.enable": true,
  "coc.source.buffer.priority": 10,
  "coc.source.buffer.ignoreGitignore": true,
  "semanticTokens.enable": true,
  "java.saveActions.organizeImports": true,
  "java.maven.downloadSources": false,
  "java.maven.updateSnapshots": false,
  "java.contentProvider.preferred": "fernflower",
  "snippets.ultisnips.pythonPrompt": false,
  "diagnostic.enable": true,
  "diagnostic.virtualText": true,
  "diagnostic.virtualTextCurrentLineOnly": false,
  "diagnostic.errorSign": "E",
  "diagnostic.warningSign": "W",
  "diagnostic.messageTarget": "echo",
  "java.referencesCodeLens.enabled": true,
  "java.implementationsCodeLens.enabled": true,
  "typescript.referencesCodeLens.enabled": true,
  "typescript.implementationsCodeLens.enabled": true,
  "javascript.referencesCodeLens.enabled": true,
  "javascript.implementationsCodeLens.enabled": true,
  "Lua.codeLens.enable": true,
  "boot-java.change-detection.on": true,
  "boot-java.embedded-syntax-highlighting": true,
  "boot-java.highlight-codelens.on": true,
  "boot-java.validation.java.boot3": "ON",
  "boot-java.validation.java.boot2": "ON",
  "boot-java.validation.java.version-validation": "ON",
  "boot-java.validation.spel.on": "ON",
  "boot-java.validation.data-query": "ON",
  "boot-java.support-spring-xml-config.on": true,
  "boot-java.support-spring-xml-config.hyperlinks": true,
  "boot-java.support-spring-xml-config.content-assist": true,
  "boot-java.validation.java.spring-aot": "ON",
  "boot-java.modulith-project-tracking": true,
  "boot-java.live-information.automatic-connection.on": true,
  "boot-java.live-information.all-local-java-processes": true,
  "boot-java.live-information.fetch-data.max-retries": 5,
  "boot-java.live-information.fetch-data.retry-delay-in-seconds": 3,
  "java.imports.gradle.wrapper.checksums": [
    {
      "sha256": "423cb469ccc0ecc31f0e4e1c309976198ccb734cdcbb7029d4bda0f18f57e8d9",
      "allowed": false
    }
  ],
  "extensions.updateCheck": "daily",
  "languageserver": {
    "buf": {
      "command": "buf",
      "args": [
        "beta",
        "lsp"
      ],
      "filetypes": [
        "proto"
      ]
    }
  },
}
